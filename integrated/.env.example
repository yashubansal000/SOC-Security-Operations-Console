# Copy to .env and fill in a real key to enable LIVE LLM narratives (Groq).
# If left unset, the agent automatically uses deterministic template
# narratives — the pipeline runs fully offline and the demo cannot hard-fail.
GROQ_API_KEY=
# Optional model override (default: openai/gpt-oss-120b)
GROQ_MODEL=openai/gpt-oss-120b
